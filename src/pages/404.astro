---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 — Halaman tidak ditemukan | ADOSISTERING"
  description="Halaman yang Anda cari tidak ditemukan. Kembali ke beranda ADOSISTERING."
>
  <main
    id="konten-utama"
    class="min-h-screen flex items-center justify-center bg-gradient-to-b from-white to-primary-50 px-4"
  >
    <div class="text-center max-w-xl">
      <p
        class="text-sm font-semibold tracking-widest text-primary-600 uppercase mb-4"
      >
        Error 404
      </p>
      <h1
        class="text-5xl sm:text-6xl md:text-7xl font-extrabold text-primary-700 mb-6"
      >
        Halaman tidak ditemukan
      </h1>
      <p class="text-base sm:text-lg text-neutral-600 leading-relaxed mb-10">
        Sepertinya halaman yang Anda tuju sudah dipindahkan atau tidak pernah
        ada. Mari kembali ke beranda untuk menjelajah ADOSISTERING.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-7 py-3 bg-primary-600 text-white font-semibold rounded-full hover:bg-primary-700 transition-colors duration-200"
        >
          Kembali ke Beranda
        </a>
        <a
          href="/#hubungi-kami"
          class="inline-flex items-center justify-center gap-2 px-7 py-3 bg-white text-primary-700 font-semibold rounded-full border-2 border-primary-600 hover:bg-primary-50 transition-colors duration-200"
        >
          Hubungi Kami
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
