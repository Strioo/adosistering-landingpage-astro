---
import SeoHead from "@/components/SeoHead.astro";
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, unknown>[];
}

const { title, description, canonical, ogImage, schema } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUT/CLS — fallback system font until web font is loaded -->
    <!-- Critical CSS inlined for fastest FCP/LCP -->
    <style is:inline>
      body { font-family: system-ui, -apple-system, sans-serif; }
      /* Reserve hero space to prevent CLS */
      #beranda { min-height: 600px; position: relative; overflow: hidden; }
      @media (min-width: 768px) { #beranda { min-height: 700px; } }
      @media (min-width: 1024px) { #beranda { min-height: 800px; } }
      /* Ensure LCP image renders immediately */
      #beranda img { display: block; width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }
    </style>

    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      schema={schema}
    />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <!-- Skip Navigation Link (Accessibility) -->
    <a
      href="#konten-utama"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:text-sm focus:font-semibold"
    >
      Langsung ke konten utama
    </a>

    <slot />

    <!-- Minimal inline JS for smooth scroll -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        /* ── Smooth scroll for anchor links ──
         *  Uses JS-based smooth scroll with offset for the sticky header.
         *  More reliable cross-browser than CSS scroll-behavior alone,
         *  and correctly accounts for the navbar height.
         */
        var headerEl = document.querySelector("header");
        document.querySelectorAll('a[href^="#"]').forEach(function (anchor) {
          anchor.addEventListener("click", function (e) {
            var targetId = this.getAttribute("href");
            if (!targetId || targetId === "#") return;
            var target = document.querySelector(targetId);
            if (!target) return;
            e.preventDefault();
            var headerOffset = headerEl ? headerEl.offsetHeight : 0;
            var elementPosition = target.getBoundingClientRect().top + window.scrollY;
            window.scrollTo({
              top: elementPosition - headerOffset,
              behavior: "smooth",
            });
            // Update URL hash without jumping
            history.pushState(null, "", targetId);
          });
        });
      });
    </script>
  </body>
</html>
