---
/**
 * PreviewSection.astro — Product preview section
 * Design: Centered heading + subtitle + CTA button, laptop mockup image
 * sitting on top of an abstract green circle background shape.
 * Matches the provided design comp exactly.
 */
export interface Props {
  title?: string;
  subtitle?: string;
  cta?: { label: string; href: string };
}

const {
  title = "Sistem Irigasi Pintar\nUntuk Pertanian Efisien",
  subtitle = "Monitoring kelembaban tanah, debit air, dan kontrol pompa secara real-time dalam satu platform terintegrasi.",
  cta = { label: "Hubungi Kami", href: "#hubungi-kami" },
} = Astro.props;
---

<section
  id="preview"
  class="relative bg-white py-20 md:py-28 overflow-hidden"
  aria-label="Preview Platform"
>
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header content — centered -->
    <div class="text-center max-w-2xl mx-auto">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-primary-600 leading-tight italic"
      >
        {title.split("\n").map((line, i) => (
          <span class:list={[i > 0 && "block"]}>{line}</span>
        ))}
      </h2>

      <p class="mt-5 text-base sm:text-lg text-neutral-500 leading-relaxed">
        {subtitle}
      </p>

      <!-- CTA Button -->
      <div class="mt-7">
        <a
          href={cta.href}
          class="inline-flex items-center justify-center px-8 py-3
                 bg-neutral-800 text-white text-sm font-semibold rounded-full
                 border border-neutral-700
                 hover:bg-neutral-900 transition-all duration-200"
        >
          {cta.label}
        </a>
      </div>
    </div>

    <!-- Laptop Mockup with abstract background shape -->
    <div class="relative mt-16 md:mt-20 flex justify-center">
      <!-- Abstract green circle blob — behind the laptop -->
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
               w-[320px] h-[320px] sm:w-[420px] sm:h-[420px] md:w-[520px] md:h-[520px] lg:w-[600px] lg:h-[600px]
               rounded-full bg-primary-600 opacity-90 blur-[2px]"
        aria-hidden="true"
      >
      </div>

      <!-- Laptop image -->
      <img
        src="/images/laptop-mockup.jpg"
        alt="Dashboard platform ADOSISTERING ditampilkan di layar laptop — monitoring irigasi, peta lokasi, kontrol sprayer, dan data kelembaban tanah secara real-time"
        width="900"
        height="560"
        class="relative z-10 w-full max-w-3xl h-auto drop-shadow-2xl"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
