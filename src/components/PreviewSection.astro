---
import { Image } from "astro:assets";
import laptopMockup from "@/assets/images/laptop-mockup.png";

export interface Props {
  title?: string;
  subtitle?: string;
  cta?: { label: string; href: string };
}

const {
  title = "Sistem Irigasi Pintar\nUntuk Pertanian Efisien",
  subtitle = "Monitoring kelembaban tanah, debit air, dan kontrol pompa secara real-time dalam satu platform terintegrasi.",
  cta = { label: "Hubungi Kami", href: "#hubungi-kami" },
} = Astro.props;
---

<section
  id="preview"
  class="relative bg-white py-20 md:py-28 overflow-hidden"
  aria-label="Preview Platform"
>
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header content — centered -->
    <div class="text-center max-w-2xl mx-auto">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-primary-600 leading-tight"
      >
        {title.split("\n").map((line, i) => (
          <span class:list={[i > 0 && "block"]}>{line}</span>
        ))}
      </h2>

      <p class="mt-5 text-base sm:text-lg text-neutral-500 leading-relaxed">
        {subtitle}
      </p>

      <!-- CTA Button -->
      <div class="mt-7">
        <a
          href={cta.href}
          class="inline-flex items-center justify-center px-8 py-3
                 bg-neutral-800 text-white text-sm font-semibold rounded-full
                 border border-neutral-700
                 hover:bg-neutral-900 transition-all duration-200"
        >
          {cta.label}
        </a>
      </div>
    </div>

    <!-- Laptop Mockup with oval green background shape -->
    <div class="relative mt-14 md:mt-16 flex justify-center items-end min-h-[460px] sm:min-h-[520px] md:min-h-[600px]">
      

      <!-- Laptop image — sits above the oval, z-10 -->
      <Image
        src={laptopMockup}
        alt="Dashboard platform ADOSISTERING ditampilkan di layar laptop — monitoring irigasi, peta lokasi, kontrol sprayer, dan data kelembaban tanah secara real-time"
        width={680}
        height={424}
        quality={75}
        sizes="(max-width: 768px) 95vw, (max-width: 1280px) 70vw, 680px"
        class="relative z-10 w-full max-w-[680px] h-auto drop-shadow-2xl mb-0"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
