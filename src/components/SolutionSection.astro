---
import { Image } from "astro:assets";
import solutionTitle from "@/assets/images/solution-title.png";
import solutionFeature from "@/assets/images/solution-feature.png";
import iconWater from "@/assets/images/water.svg";
import iconClock from "@/assets/images/clock.svg";
import iconData from "@/assets/images/data.svg";
import iconScale from "@/assets/images/scale.svg";

const highlights = [
  {
    icon: iconWater,
    title: "Hemat Air",
    description: "Penyiraman berdasarkan kondisi tanah dan kebutuhan tanaman.",
  },
  {
    icon: iconClock,
    title: "Efisiensi Waktu",
    description: "Monitoring dan kontrol irigasi jarak jauh via website.",
  },
  {
    icon: iconData,
    title: "Data Real-Time",
    description: "Keputusan irigasi berdasarkan data, bukan perkiraan.",
  },
  {
    icon: iconScale,
    title: "Skalabel",
    description: "Dapat diterapkan pada berbagai macam jenis lahan.",
  },
];
---

<section
  id="solusi"
  class="bg-white overflow-hidden"
  aria-labelledby="solusi-heading"
>
  <!-- ── Upper area (white bg) ─────────────────────────────────── -->
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16 pt-16 md:pt-24 lg:pt-32">

    <!-- Title image — centered -->
    <div class="flex justify-center mb-16 md:mb-20">
      <Image
        src={solutionTitle}
        alt="Solusi Irigasi Cerdas"
        width={480}
        quality={75}
        class="h-auto w-auto max-w-[240px] sm:max-w-[340px] md:max-w-[420px] lg:max-w-[480px]"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Main content: text left + phone mockup right -->
    <!-- The phone image sits above the green strip, so we let it overflow downward -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-end">

      <!-- Left — heading + description, vertically centered against phone -->
      <div class="pb-16 md:pb-24 lg:pb-32">
        <h2
          id="solusi-heading"
          class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-primary-600 leading-tight"
        >
          Sistem Irigasi dalam Satu Platform Terintegrasi
        </h2>
        <p class="mt-5 text-base sm:text-lg text-neutral-500 leading-relaxed max-w-lg">
          ADOSISTERING mengintegrasikan sensor, kontrol pompa, dan dashboard
          monitoring untuk membantu petani mengambil keputusan irigasi yang
          tepat.
        </p>
      </div>

      <!-- Right — phone mockup (extends down into the green strip) -->
      <div class="flex justify-center lg:justify-end">
        <Image
          src={solutionFeature}
          alt="Tampilan aplikasi mobile dan dashboard ADOSISTERING menampilkan login, peta lokasi, data sprayer, dan kontrol irigasi"
          width={640}
          quality={75}
          sizes="(max-width: 768px) 90vw, (max-width: 1280px) 45vw, 640px"
          class="w-full max-w-[480px] lg:max-w-[600px] h-auto relative z-10"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>

  <!-- ── Bottom green strip ──────────────────────────────────────── -->
  <div class="bg-primary-500 -mt-1">
    <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16 py-14 md:py-16 lg:py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-8 lg:gap-12">
        {highlights.map((item) => (
          <div class="text-center">
            <!-- Icon in white circle -->
            <div class="flex justify-center mb-5">
              <div class="w-20 h-20 sm:w-24 sm:h-24 bg-white rounded-full flex items-center justify-center shadow-md">
                <Image
                  src={item.icon}
                  alt=""
                  width={52}
                  height={52}
                  class="w-11 h-11 sm:w-12 sm:h-12"
                  loading="lazy"
                />
              </div>
            </div>
            <!-- Title -->
            <h3 class="text-base sm:text-lg font-bold text-white mb-2">
              {item.title}
            </h3>
            <!-- Description -->
            <p class="text-xs sm:text-sm text-white/80 leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
