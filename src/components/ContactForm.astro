---
/**
 * ContactForm.astro — "Hubungi Kami" contact section
 * Design: Two-column — form left, image right.
 * Below: 3 contact-info cards with icons.
 *
 * Submission strategy: frontend-only via `mailto:` link.
 * On submit, the user's default mail client opens with subject + body
 * pre-filled, addressed to RECIPIENT_EMAIL. No backend, no API keys.
 */
import { Image } from "astro:assets";
import contactFeature from "@/assets/images/contact-feature.png";
import iconTelephone from "@/assets/images/telephone.svg";
import iconService from "@/assets/images/service.svg";
import iconMessage from "@/assets/images/message.svg";

const RECIPIENT_EMAIL = "adosisteringteam@gmail.com";

const contactCards = [
  {
    icon: iconTelephone,
    title: "Telepon & WhatsApp",
    lines: ["(0281) 641629", "+62 812-3994-2119"],
  },
  {
    icon: iconService,
    title: "Waktu Pelayanan",
    lines: ["Daily: 08:00-16:00", "Weekend: 10:00-15:00"],
  },
  {
    icon: iconMessage,
    title: "Sampaikan Pesan",
    lines: ["adosisteringteam@gmail.com", "purwokerto.telkomuniversity.ac.id"],
  },
];
---

<section
  id="hubungi-kami"
  class="bg-white py-16 md:py-24 lg:py-32"
  aria-labelledby="kontak-heading"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16">

    <!-- ── Top: form left + image right ────────────────────────── -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start mb-20 md:mb-28">

      <!-- LEFT — title + form -->
      <div>
        <h2
          id="kontak-heading"
          class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.25rem] font-extrabold text-primary-500 leading-tight mb-10"
        >
          Hubungi Kami
        </h2>

        <form
          id="contact-form"
          class="space-y-6"
          novalidate
          data-recipient={RECIPIENT_EMAIL}
        >
          <!-- Row: Nama + Email -->
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="form-group">
              <label for="nama" class="form-label">Nama</label>
              <input
                type="text"
                id="nama"
                name="nama"
                required
                autocomplete="name"
                placeholder="Nama Lengkap"
                class="form-input"
                aria-required="true"
              />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="Alamat email"
                class="form-input"
                aria-required="true"
              />
            </div>
          </div>

          <!-- Row: Nomor Telepon / WA + Tipe Pengguna -->
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="form-group">
              <label for="telepon" class="form-label">Nomor Telepon / WA</label>
              <input
                type="tel"
                id="telepon"
                name="telepon"
                autocomplete="tel"
                placeholder="Nomor yang dapat dihubungi"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label class="form-label">Tipe Pengguna</label>
              <!-- Hidden real input for form submission -->
              <input type="hidden" id="tipe-pengguna" name="tipe_pengguna" />
              <!-- Custom dropdown -->
              <div class="custom-dropdown" id="dropdown-tipe">
                <button
                  type="button"
                  class="custom-dropdown__trigger"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  id="dropdown-tipe-trigger"
                >
                  <span class="custom-dropdown__label" data-placeholder="Pilih tipe pengguna">Pilih tipe pengguna</span>
                  <svg class="custom-dropdown__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <ul class="custom-dropdown__list" role="listbox" aria-labelledby="dropdown-tipe-trigger">
                  <li class="custom-dropdown__item" role="option" data-value="petani">Petani</li>
                  <li class="custom-dropdown__item" role="option" data-value="peneliti">Peneliti</li>
                  <li class="custom-dropdown__item" role="option" data-value="instansi">Instansi Pemerintah</li>
                  <li class="custom-dropdown__item" role="option" data-value="perusahaan">Perusahaan</li>
                  <li class="custom-dropdown__item" role="option" data-value="lainnya">Lainnya</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Pesan / Instruksi Khusus -->
          <div class="form-group">
            <label for="pesan" class="form-label">Pesan / Instruksi Khusus</label>
            <textarea
              id="pesan"
              name="pesan"
              required
              rows="5"
              placeholder="Apakah ada yang perlu kami ketahui?"
              class="form-input form-textarea"
              aria-required="true"
            ></textarea>
          </div>

          <!-- Honeypot -->
          <div class="hidden" aria-hidden="true">
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Status message -->
          <div
            id="form-status"
            class="hidden text-sm text-center py-3 rounded-lg"
            role="alert"
          ></div>

          <button type="submit" class="btn-primary text-base py-3.5 px-10">
            Kirim Pesan
          </button>
        </form>
      </div>

      <!-- RIGHT — contact feature image -->
      <div class="flex justify-center lg:justify-end items-start">
        <Image
          src={contactFeature}
          alt="Tim ADOSISTERING siap membantu konsultasi sistem irigasi cerdas"
          width={600}
          quality={75}
          sizes="(max-width: 768px) 90vw, (max-width: 1280px) 45vw, 600px"
          class="w-full max-w-[520px] lg:max-w-[580px] h-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- ── Bottom: 3 contact info cards ────────────────────────── -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {contactCards.map((card) => (
        <div class="text-center">
          <!-- Icon -->
          <div class="flex justify-center mb-4">
            <Image
              src={card.icon}
              alt=""
              width={56}
              height={56}
              class="w-12 h-12 sm:w-14 sm:h-14"
              loading="lazy"
            />
          </div>
          <!-- Title -->
          <h3 class="text-lg sm:text-xl font-bold text-neutral-900 mb-2">
            {card.title}
          </h3>
          <!-- Info lines -->
          {card.lines.map((line) => (
            <p class="text-sm sm:text-base text-neutral-500 leading-relaxed">
              {line}
            </p>
          ))}
        </div>
      ))}
    </div>

  </div>

  <!-- Frontend-only submission via mailto: -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      var form = document.getElementById("contact-form");
      var status = document.getElementById("form-status");
      if (!form || !status) return;

      var recipient = form.dataset.recipient || "";

      function setFieldError(field, hasError) {
        if (!field) return;
        if (hasError) {
          field.classList.add("is-error");
          field.setAttribute("aria-invalid", "true");
        } else {
          field.classList.remove("is-error");
          field.removeAttribute("aria-invalid");
        }
      }

      function showStatus(message, tone) {
        var palette = {
          success: "bg-green-50 text-green-700",
          error: "bg-red-50 text-red-700",
          info: "bg-yellow-50 text-yellow-800",
        };
        status.textContent = message;
        status.className =
          "text-sm text-center py-3 rounded-lg " + (palette[tone] || palette.info);
        status.classList.remove("hidden");
      }

      form.addEventListener("submit", function (e) {
        e.preventDefault();

        var nama = form.querySelector("#nama");
        var email = form.querySelector("#email");
        var telepon = form.querySelector("#telepon");
        var tipe = form.querySelector("#tipe-pengguna");
        var pesan = form.querySelector("#pesan");
        var honeypot = form.querySelector('[name="_gotcha"]');

        // Honeypot — silent reject
        if (honeypot && honeypot.value) {
          return;
        }

        var valid = true;
        [nama, email, pesan].forEach(function (field) {
          if (field && !field.value.trim()) {
            setFieldError(field, true);
            valid = false;
          } else {
            setFieldError(field, false);
          }
        });

        if (
          email &&
          email.value &&
          !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)
        ) {
          setFieldError(email, true);
          valid = false;
        }

        if (!valid) {
          showStatus("Mohon lengkapi semua field yang wajib diisi.", "error");
          return;
        }

        if (!recipient) {
          showStatus(
            "Alamat tujuan email belum diatur. Silakan hubungi kami melalui WhatsApp.",
            "info"
          );
          return;
        }

        // Build email body
        var namaVal = nama.value.trim();
        var emailVal = email.value.trim();
        var teleponVal = telepon ? telepon.value.trim() : "";
        var tipeVal = tipe ? tipe.value.trim() : "";
        var pesanVal = pesan.value.trim();

        var subject = "Pesan dari " + namaVal + " via website ADOSISTERING";
        var bodyLines = [
          "Halo Tim ADOSISTERING,",
          "",
          "Saya menghubungi Anda melalui form di website. Berikut detail saya:",
          "",
          "Nama          : " + namaVal,
          "Email         : " + emailVal,
          "Telepon / WA  : " + (teleponVal || "-"),
          "Tipe Pengguna : " + (tipeVal || "-"),
          "",
          "Pesan:",
          pesanVal,
          "",
          "Terima kasih.",
        ];
        var body = bodyLines.join("\r\n");

        var mailtoUrl =
          "mailto:" +
          encodeURIComponent(recipient) +
          "?subject=" +
          encodeURIComponent(subject) +
          "&body=" +
          encodeURIComponent(body);

        // Open user's mail client
        window.location.href = mailtoUrl;

        showStatus(
          "Membuka aplikasi email Anda. Silakan tekan kirim untuk menyelesaikan pengiriman.",
          "success"
        );

        // Reset form after a short delay so the mail client has time to open
        setTimeout(function () {
          form.reset();
          // Reset custom dropdown label
          var trigger = document.getElementById("dropdown-tipe-trigger");
          var label = trigger
            ? trigger.querySelector(".custom-dropdown__label")
            : null;
          if (trigger && label) {
            trigger.classList.remove("has-value");
            label.textContent =
              label.dataset.placeholder || "Pilih tipe pengguna";
          }
        }, 800);
      });

      // Clear aria-invalid on user input
      ["nama", "email", "pesan"].forEach(function (id) {
        var field = form.querySelector("#" + id);
        if (!field) return;
        field.addEventListener("input", function () {
          if (field.classList.contains("is-error")) {
            setFieldError(field, false);
          }
        });
      });
    });
  </script>

  <!-- Custom dropdown behaviour -->
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      var dropdown = document.getElementById("dropdown-tipe");
      if (!dropdown) return;

      var trigger  = dropdown.querySelector(".custom-dropdown__trigger");
      var list     = dropdown.querySelector(".custom-dropdown__list");
      var label    = dropdown.querySelector(".custom-dropdown__label");
      var hidden   = document.getElementById("tipe-pengguna");
      var items    = dropdown.querySelectorAll(".custom-dropdown__item");

      function open() {
        trigger.classList.add("is-open");
        list.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      }

      function close() {
        trigger.classList.remove("is-open");
        list.classList.remove("is-open");
        trigger.setAttribute("aria-expanded", "false");
      }

      trigger.addEventListener("click", function (e) {
        e.stopPropagation();
        trigger.classList.contains("is-open") ? close() : open();
      });

      items.forEach(function (item) {
        item.addEventListener("click", function () {
          var value = item.dataset.value;
          var text  = item.textContent.trim();

          /* Update label */
          label.textContent = text;
          /* Mark as having a value */
          trigger.classList.add("has-value");
          /* Update hidden input */
          hidden.value = value;
          /* Mark selected item */
          items.forEach(function (i) { i.classList.remove("is-selected"); });
          item.classList.add("is-selected");

          close();
        });
      });

      /* Close on outside click */
      document.addEventListener("click", function (e) {
        if (!dropdown.contains(e.target)) close();
      });

      /* Close on Escape key */
      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") close();
      });
    });
  </script>
</section>
