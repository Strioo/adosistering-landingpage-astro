---
import { Image } from "astro:assets";
import direktorImg from "@/assets/images/direktur-image.png";
---

<section
  class="relative bg-white overflow-hidden"
  aria-labelledby="direktur-heading"
>
  <!-- Green background — covers the bottom 62% of the section -->
  <div class="absolute bottom-0 left-0 right-0 h-[52%] bg-primary-500 z-0" aria-hidden="true"></div>

  <div class="relative z-10 container-full px-4 sm:px-6 lg:px-12 xl:px-16">
    <div class="grid lg:grid-cols-[38%_62%] items-stretch min-h-[420px] md:min-h-[460px] lg:min-h-[500px] h-full">

      <!-- LEFT — Director photo, pinned to bottom of section -->
      <div class="flex items-end justify-center lg:justify-start">
        <Image
          src={direktorImg}
          alt="Foto Sudianto, S.Pd., M.Kom. — Direktur ADOSISTERING"
          width={440}
          quality={85}
          class="w-[220px] sm:w-[260px] md:w-[320px] lg:w-[380px] xl:w-[420px] h-auto object-contain object-bottom"
          loading="lazy"
        />
      </div>

      <!-- RIGHT — title in white zone + quote in green zone -->
      <div class="flex flex-col pl-6 md:pl-10 lg:pl-16">

        <!-- White zone portion — title vertically centered here -->
        <div class="h-[48%] flex items-center justify-end">
          <h2
            id="direktur-heading"
            class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.25rem] font-extrabold text-primary-500 leading-tight text-right"
          >
            Pandangan Direktur
          </h2>
        </div>

        <!-- Green zone portion — quote + name vertically centered here -->
        <div class="h-[52%] flex flex-col justify-center pb-6 md:pb-8 lg:pb-10">
          <blockquote class="mb-6 md:mb-8">
            <p class="text-lg sm:text-xl md:text-[1.35rem] lg:text-[1.5rem] text-white leading-relaxed">
              &ldquo;Pemanfaatan teknologi berbasis data dalam sistem irigasi menjadi langkah penting untuk meningkatkan efisiensi dan keberlanjutan pertanian.&rdquo;
            </p>
          </blockquote>

          <cite class="not-italic block text-xl sm:text-2xl md:text-2xl lg:text-3xl font-bold text-white leading-snug">
            Sudianto, S.Pd., M.Kom.
          </cite>
          <p class="text-sm sm:text-base text-white/70 mt-1.5">
            Direktur
          </p>
        </div>

      </div>
    </div>
  </div>
</section>
