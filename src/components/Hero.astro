---
/**
 * Hero.astro — Main hero section
 * Design: Green gradient background, H1 heading, subtitle, 2 CTA buttons, phone mockup image
 * "Sistem Irigasi Pintar Untuk Pertanian Efisien"
 */
export interface Props {
  title?: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  title = "Sistem Irigasi Pintar\nUntuk Pertanian Efisien",
  subtitle = "Sistem irigasi cerdas berbasis IoT untuk mengoptimalkan penggunaan air, meningkatkan hasil panen, dan memudahkan petani dalam mengelola irigasi lahan pertanian secara otomatis dan jarak jauh.",
  primaryCta = { label: "Mulai Sekarang", href: "#hubungi-kami" },
  secondaryCta = { label: "Pelajari Lebih Lanjut", href: "#masalah" },
} = Astro.props;
---

<section
  id="beranda"
  class="relative overflow-hidden bg-gradient-to-br from-primary-800 via-primary-700 to-primary-600"
  aria-label="Hero — Sistem Irigasi Pintar"
>
  <!-- Decorative background pattern -->
  <div
    class="absolute inset-0 opacity-10"
    aria-hidden="true"
  >
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hero-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="1.5" fill="white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#hero-pattern)" />
    </svg>
  </div>

  <div class="relative container-wide mx-auto section-padding">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[70vh] lg:min-h-[80vh]">
      <!-- Text Content -->
      <div class="text-center lg:text-left order-2 lg:order-1">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-display-lg font-extrabold text-white leading-tight text-balance">
          {title.split("\n").map((line, i) => (
            <span class:list={[i > 0 && "block mt-2"]}>
              {i === 1 ? (
                <span class="text-accent-300">{line}</span>
              ) : (
                line
              )}
            </span>
          ))}
        </h1>

        <p class="mt-6 text-base sm:text-lg text-white/80 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          {subtitle}
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href={primaryCta.href}
            class="btn-accent text-base px-8 py-3.5 shadow-lg hover:shadow-xl transition-all duration-300"
          >
            {primaryCta.label}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-colors duration-200"
          >
            {secondaryCta.label}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="mt-10 flex flex-wrap gap-6 items-center justify-center lg:justify-start text-white/60 text-sm">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span>Berbasis IoT</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span>Energi Surya</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span>Monitoring Real-time</span>
          </div>
        </div>
      </div>

      <!-- Hero Image / App Mockup -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative w-full max-w-md lg:max-w-lg">
          <!-- TODO: replace with actual hero image / app screenshot -->
          <img
            src="/images/placeholder-dashboard.svg"
            alt="Dashboard aplikasi monitoring irigasi ADOSISTERING menampilkan data kelembaban tanah dan kontrol pompa air secara real-time"
            width="800"
            height="600"
            class="w-full h-auto rounded-2xl shadow-elevated"
            loading="eager"
            fetchpriority="high"
          />
          <!-- Floating badge -->
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-card p-3 flex items-center gap-3 animate-fade-in">
            <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M22 4L12 14.01l-3-3" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-neutral-500">Status Sensor</p>
              <p class="text-sm font-bold text-primary-700">Aktif & Terhubung</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="absolute bottom-0 left-0 right-0" aria-hidden="true">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 50L48 45.7C96 41.3 192 32.7 288 37.2C384 41.7 480 59.3 576 62.8C672 66.3 768 55.7 864 47.8C960 40 1056 35 1152 38.3C1248 41.7 1344 53.3 1392 59.2L1440 65V100H1392C1344 100 1248 100 1152 100C1056 100 960 100 864 100C768 100 672 100 576 100C480 100 384 100 288 100C192 100 96 100 48 100H0V50Z" fill="white"/>
    </svg>
  </div>
</section>
