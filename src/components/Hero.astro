---
/**
 * Hero.astro — Full-width hero section with background image + dark overlay
 * Design: `/images/hero-background.jpg` as bg, semi-transparent dark overlay,
 * fixed 800px height, left-aligned "ADOSISTERING" heading + IoT subtitle.
 */
export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "ADOSISTERING",
  subtitle = "Sistem Irigasi Cerdas Berbasis IoT untuk Mengoptimalkan Pengairan Lahan Kering",
} = Astro.props;
---

<section
  id="beranda"
  class="relative overflow-hidden"
  style="height: 800px;"
  aria-label="Hero — Sistem Irigasi Cerdas"
>
  <!-- Background image -->
  <img
    src="/images/hero-background.jpg"
    alt=""
    role="presentation"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex items-center">
    <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <!-- Heading -->
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] tracking-tight"
        >
          {title}
        </h1>

        <!-- Subtitle -->
        <p
          class="mt-5 text-base sm:text-lg md:text-xl text-white/80 leading-relaxed max-w-xl"
        >
          {subtitle}
        </p>
      </div>
    </div>
  </div>
</section>
