---
import { Image } from "astro:assets";
import heroBg from "@/assets/images/hero-background.jpg";

export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "ADOSISTERING",
  subtitle = "Sistem Irigasi Cerdas Berbasis IoT untuk Mengoptimalkan Pengairan Lahan Kering",
} = Astro.props;
---

<section
  id="beranda"
  class="relative overflow-hidden"
  style="height: 800px;"
  aria-label="Hero — Sistem Irigasi Cerdas"
>
  <!-- Background image -->
  <Image
    src={heroBg}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
    quality={85}
    widths={[768, 1280, 1920]}
    sizes="100vw"
  />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex items-center pb-24">
    <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16">
      <div class="max-w-2xl">
        <!-- Heading -->
        <h1
          class="text-4xl sm:text-5xl md:text-6xl lg:text-6xl font-extrabold text-white leading-[1.1] tracking-widest text-left"
        >
          {title}
        </h1>

        <!-- Subtitle -->
        <p
          class="mt-5 text-lg sm:text-2xl md:text-3xl text-white/80 leading-relaxed max-w-xl text-left"
        >
          {subtitle}
        </p>
      </div>
    </div>
  </div>
</section>
