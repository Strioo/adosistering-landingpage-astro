---
/**
 * Header.astro — Sticky navigation bar
 * Design: Green background, white logo, nav links, CTA button
 */
const navLinks = [
  { href: "#beranda", label: "Beranda" },
  { href: "#masalah", label: "Masalah" },
  { href: "#solusi", label: "Solusi" },
  { href: "#fitur", label: "Fitur" },
  { href: "#lokasi", label: "Lokasi" },
  { href: "#hubungi-kami", label: "Hubungi Kami" },
];
---

<header
  class="sticky top-0 z-50 bg-primary-800/95 backdrop-blur-md border-b border-primary-700/50"
  role="banner"
>
  <nav
    class="container-wide mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-8 h-16 md:h-18"
    aria-label="Navigasi utama"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 shrink-0"
      aria-label="ADOSISTERING — Kembali ke beranda"
    >
      <!-- TODO: replace with actual logo uploaded to /public/logos/ -->
      <img
        src="/logos/logo-placeholder.svg"
        alt="Logo ADOSISTERING"
        width="160"
        height="36"
        class="h-8 md:h-9 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="px-3 py-2 text-sm font-medium text-white/90 hover:text-white hover:bg-white/10 rounded-lg transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Desktop CTA -->
    <a
      href="#hubungi-kami"
      class="hidden lg:inline-flex items-center gap-2 px-5 py-2.5 bg-white text-primary-800 text-sm font-semibold rounded-lg hover:bg-primary-50 transition-colors duration-200"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path
          d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path>
      </svg>
      Hubungi Kami
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 text-white hover:bg-white/10 rounded-lg transition-colors"
      aria-label="Buka menu navigasi"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-primary-800 border-t border-primary-700/50"
    role="navigation"
    aria-label="Menu mobile"
  >
    <ul class="px-4 py-4 space-y-1" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block px-4 py-3 text-white/90 hover:text-white hover:bg-white/10 rounded-lg text-sm font-medium transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a
          href="#hubungi-kami"
          class="block text-center px-4 py-3 bg-white text-primary-800 rounded-lg text-sm font-semibold hover:bg-primary-50 transition-colors"
        >
          Hubungi Kami
        </a>
      </li>
    </ul>
  </div>
</header>
