---
import { Image } from "astro:assets";
import logoIcon from "@/assets/logos/logo.svg";

const navLinks = [
  { href: "#beranda", label: "Beranda" },
  { href: "#fitur", label: "Fitur" },
  { href: "#implementasi", label: "Implementasi" },
  { href: "#mitra-kami", label: "Mitra Kami" },
];
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  role="banner"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16 pt-5">
    <nav
      id="main-nav"
      class="flex items-center justify-between px-5 sm:px-6 lg:px-8 py-3.5
             rounded-full bg-white/15 backdrop-blur-xl border border-white/20
             shadow-[0_8px_32px_rgba(0,0,0,0.12)] transition-all duration-300"
      aria-label="Navigasi utama"
    >
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2.5 shrink-0"
        aria-label="ADOSISTERING — Kembali ke beranda"
      >
        <Image
          src={logoIcon}
          alt=""
          aria-hidden="true"
          width={32}
          height={49}
          class="h-10 w-auto"
          loading="eager"
        />
        <span
          class="text-white font-semibold tracking-wide leading-none"
          style="font-family: 'Oswald', sans-serif; font-size: 1.25rem; letter-spacing: 0.05em;"
        >
          ADOSISTERING
        </span>
      </a>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Desktop nav links -->
        <ul class="hidden lg:flex items-center gap-1" role="list">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="px-4 py-2 text-sm font-medium text-white/90 hover:text-white
                       hover:bg-white/10 rounded-full transition-all duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Desktop CTA -->
        <a
          href="#hubungi-kami"
          class="hidden lg:inline-flex items-center px-7 py-2.5
                 bg-neutral-800/80 text-white text-sm font-semibold rounded-full
                 hover:bg-neutral-900 transition-all duration-200"
        >
          Hubungi Kami
        </a>

        <!-- Mobile hamburger button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="lg:hidden flex items-center justify-center w-10 h-10 text-white
                 hover:bg-white/10 rounded-full transition-colors duration-200"
          aria-label="Buka menu navigasi"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-burger" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-x" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="hidden mx-4 sm:mx-6 mt-2"
    role="navigation"
    aria-label="Menu mobile"
  >
    <div class="rounded-2xl bg-neutral-900/95 backdrop-blur-xl border border-white/10
                shadow-[0_8px_32px_rgba(0,0,0,0.3)] overflow-hidden">
      <ul class="px-3 py-3 space-y-1" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link flex items-center px-4 py-3 text-white/90
                     hover:text-white hover:bg-white/10 rounded-xl text-sm font-medium
                     transition-colors duration-150"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="px-1 pt-1 pb-1">
          <a
            href="#hubungi-kami"
            class="mobile-nav-link flex items-center justify-center px-4 py-3
                   bg-primary-600 text-white rounded-xl text-sm font-semibold
                   hover:bg-primary-700 transition-colors duration-150"
          >
            Hubungi Kami
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  /* ── Mobile Menu ─────────────────────────────────────────── */
  (() => {
    /** @type {HTMLButtonElement | null} */
    const btn = /** @type {any} */ (document.getElementById("mobile-menu-btn"));
    /** @type {HTMLElement | null} */
    const menu = /** @type {any} */ (document.getElementById("mobile-menu"));
    /** @type {HTMLElement | null} */
    const iconBurger = /** @type {any} */ (document.getElementById("icon-burger"));
    /** @type {HTMLElement | null} */
    const iconX = /** @type {any} */ (document.getElementById("icon-x"));

    if (!btn || !menu) return;

    // Re-assign after null guard so closures below always see non-null values
    const safeBtn = btn;
    const safeMenu = menu;

    function openMenu() {
      safeMenu.classList.remove("hidden");
      safeBtn.setAttribute("aria-expanded", "true");
      safeBtn.setAttribute("aria-label", "Tutup menu navigasi");
      iconBurger?.classList.add("hidden");
      iconX?.classList.remove("hidden");
    }

    function closeMenu() {
      safeMenu.classList.add("hidden");
      safeBtn.setAttribute("aria-expanded", "false");
      safeBtn.setAttribute("aria-label", "Buka menu navigasi");
      iconBurger?.classList.remove("hidden");
      iconX?.classList.add("hidden");
    }

    safeBtn.addEventListener("click", function (e) {
      e.stopPropagation();
      if (safeMenu.classList.contains("hidden")) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    safeMenu.querySelectorAll(".mobile-nav-link").forEach(function (link) {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("click", function (e) {
      const header = document.getElementById("main-header");
      const target = e.target instanceof Node ? e.target : null;
      if (header && !header.contains(target)) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeMenu();
    });
  })();

  /* ── Navbar Scroll Effect ────────────────────────────────── */
  (() => {
    /** @type {HTMLElement | null} */
    const nav = /** @type {any} */ (document.getElementById("main-nav"));
    /** @type {HTMLElement | null} */
    const hero = /** @type {any} */ (document.getElementById("beranda"));
    if (!nav) return;

    const safeNav = nav;

    function updateNav() {
      const threshold = hero ? hero.offsetTop + hero.offsetHeight - 100 : 500;
      if (window.scrollY > threshold) {
        safeNav.classList.remove("bg-white/15", "border-white/20");
        safeNav.classList.add("bg-neutral-900/80", "border-neutral-700/30");
      } else {
        safeNav.classList.remove("bg-neutral-900/80", "border-neutral-700/30");
        safeNav.classList.add("bg-white/15", "border-white/20");
      }
    }

    window.addEventListener("scroll", updateNav, { passive: true });
    updateNav();
  })();
</script>