---
/**
 * Header.astro — Sticky glassmorphism navigation bar
 * Design: Frosted glass pill navbar floating over the hero.
 * White logo + nav links on the left/center, dark "Hubungi Kami" CTA pill on the right.
 * Matches the provided design comp.
 */
const navLinks = [
  { href: "#beranda", label: "Beranda" },
  { href: "#fitur", label: "Fitur" },
  { href: "#lokasi", label: "Implementasi" },
  { href: "#hubungi-kami", label: "Mitra Kami" },
];
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  role="banner"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16 pt-5">
    <!-- Glassmorphism navbar pill -->
    <nav
      class="relative flex items-center justify-between px-5 sm:px-6 lg:px-8 py-3.5
             rounded-full bg-white/15 backdrop-blur-xl border border-white/20
             shadow-[0_8px_32px_rgba(0,0,0,0.12)]"
      aria-label="Navigasi utama"
    >
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center justify-center gap-2.5 shrink-0"
        aria-label="ADOSISTERING — Kembali ke beranda"
      >
        <!-- TODO: replace with actual logo uploaded to /public/logos/ -->
        <img
          src="/logos/logo-text.svg"
          alt="Logo ADOSISTERING"
          width="180"
          height="40"
          class="h-11 md:h-12 w-auto"
          loading="eager"
        />
      </a>

      <div class="flex items-center gap-4">
        <!-- Desktop Navigation -->
        <ul class="hidden lg:flex items-center gap-1" role="list">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="nav-link px-4 py-2 text-sm font-medium text-white/90 hover:text-white
                       hover:bg-white/10 rounded-full transition-all duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Desktop CTA -->
        <a
          href="#hubungi-kami"
          class="hidden lg:inline-flex items-center gap-2 px-7 py-2.5
               bg-neutral-800/80 text-white text-sm font-semibold rounded-full
               hover:bg-neutral-900 backdrop-blur-sm
               transition-all duration-200"
        >
          Hubungi Kami
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-white hover:bg-white/10 rounded-full transition-colors"
        aria-label="Buka menu navigasi"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu (drops below the pill) -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden mx-4 sm:mx-6 lg:mx-8 mt-2"
    role="navigation"
    aria-label="Menu mobile"
  >
    <div
      class="rounded-2xl bg-white/15 backdrop-blur-xl border border-white/20
             shadow-[0_8px_32px_rgba(0,0,0,0.12)] overflow-hidden"
    >
      <ul class="px-4 py-4 space-y-1" role="list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="block px-4 py-3 text-white/90 hover:text-white hover:bg-white/10
                       rounded-xl text-sm font-medium transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="pt-2">
          <a
            href="#hubungi-kami"
            class="block text-center px-4 py-3 bg-neutral-800/80 text-white rounded-xl
                   text-sm font-semibold hover:bg-neutral-900 transition-colors"
          >
            Hubungi Kami
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));

      // Swap hamburger ↔ close icon
      const svg = btn.querySelector("svg");
      if (svg) {
        svg.innerHTML = isOpen
          ? '<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>'
          : '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>';
      }
    });

    // Close mobile menu when a link is clicked
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        const svg = btn.querySelector("svg");
        if (svg) {
          svg.innerHTML =
            '<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>';
        }
      });
    });
  }

  // Scroll-based header background transition
  // When scrolled past the hero, add a solid dark backdrop
  const header = document.getElementById("main-header");
  const heroSection = document.getElementById("beranda");

  function updateHeader() {
    if (!header) return;
    const scrollY = window.scrollY;
    const heroBottom = heroSection ? heroSection.offsetTop + heroSection.offsetHeight : 600;

    const nav = header.querySelector("nav");
    if (!nav) return;

    if (scrollY > heroBottom - 100) {
      // Past hero — solid dark glass
      nav.classList.remove("bg-white/15", "border-white/20");
      nav.classList.add("bg-neutral-900/80", "border-neutral-700/30");
    } else {
      // Over hero — light glass
      nav.classList.remove("bg-neutral-900/80", "border-neutral-700/30");
      nav.classList.add("bg-white/15", "border-white/20");
    }
  }

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();
</script>
