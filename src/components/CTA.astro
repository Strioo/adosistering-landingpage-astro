---
/**
 * CTA.astro — Call-to-action section
 * Design: Green gradient with "Bersama Mewujudkan Pertanian yang Lebih Efektif dan Berkelanjutan"
 */
export interface Props {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = "Bersama Mewujudkan Pertanian yang Lebih Efektif dan Berkelanjutan",
  subtitle = "Bergabung bersama kami dalam mengembangkan solusi irigasi cerdas berbasis IoT untuk masa depan pertanian Indonesia yang lebih baik.",
  ctaLabel = "Hubungi Kami Sekarang",
  ctaHref = "#hubungi-kami",
} = Astro.props;
---

<section
  class="relative py-20 md:py-28 bg-gradient-to-br from-primary-700 via-primary-600 to-primary-800 overflow-hidden"
  aria-label="Ajakan bertindak"
>
  <!-- Decorative circles -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-20 -left-20 w-96 h-96 bg-white/5 rounded-full"></div>
  </div>

  <div class="relative container-narrow mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl sm:text-3xl md:text-display-sm font-bold text-white leading-tight text-balance mb-6">
      {title}
    </h2>
    <p class="text-base md:text-lg text-white/80 max-w-2xl mx-auto mb-8">
      {subtitle}
    </p>
    <a
      href={ctaHref}
      class="btn-accent text-base px-10 py-4 shadow-lg hover:shadow-xl transition-all duration-300"
    >
      {ctaLabel}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
