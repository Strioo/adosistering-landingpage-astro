---
/**
 * MitraSection.astro — "Mitra Kami"
 * Design: Wooden-sign title centered, 2 partner logo cards below.
 */
import { Image } from "astro:assets";
import mitraTitle from "@/assets/images/mitra-title.png";
import telkomLogo from "@/assets/images/telkom-university-logo.png";
import pertaminaLogo from "@/assets/images/pertamina-logo.png";
import mernekjeneklogo from "@/assets/images/mernek_jenek-logo.png";

const partners = [
  {
    logo: telkomLogo,
    alt: "Telkom University — Mitra ADOSISTERING",
    name: "Telkom University",
  },
  {
    logo: pertaminaLogo,
    alt: "Pertamina — Mitra ADOSISTERING",
    name: "Pertamina",
  },
    {
    logo: mernekjeneklogo,
    alt: "MernekJenek — Mitra ADOSISTERING",
    name: "MernekJenek",
  },
];
---

<section
  id="mitra-kami"
  class="bg-white py-16 md:py-24 lg:py-32"
  aria-labelledby="mitra-heading"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16">

    <!-- Wooden sign title — centered -->
    <div class="flex justify-center mb-16 md:mb-20">
      <Image
        src={mitraTitle}
        alt="Mitra Kami"
        id="mitra-heading"
        width={480}
        quality={90}
        class="h-auto w-auto max-w-[220px] sm:max-w-[300px] md:max-w-[380px] lg:max-w-[440px]"
        loading="lazy"
      />
    </div>

    <!-- 3 partner logo cards — centered, monochrome by default, color on hover -->
    <div class="flex flex-col sm:flex-row justify-center items-center gap-6 md:gap-8 lg:gap-10">
      {partners.map((partner) => (
        <div class="group bg-neutral-100 rounded-2xl flex items-center justify-center px-8 md:px-12 py-8 md:py-10 w-full sm:w-72 md:w-80 lg:w-[340px] h-32 md:h-36 lg:h-40 transition-all duration-300 hover:shadow-md">
          <Image
            src={partner.logo}
            alt={partner.alt}
            width={280}
            quality={90}
            class="max-h-16 md:max-h-20 lg:max-h-24 w-auto object-contain grayscale group-hover:grayscale-0 transition-all duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
