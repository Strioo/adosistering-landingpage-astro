---
import { Image } from "astro:assets";
import profileSukirno from "@/assets/images/profile-sukirno.png";
import profileMuctharom from "@/assets/images/profile-muctharom.png";
import profileSuyitno from "@/assets/images/profile-suyitno.png";

const testimonials = [
  {
    name: "Sukirno",
    role: "Sekretaris Desa Dawuhan, Banyumas",
    quote: "\u201CKeterbatasan air tetap menjadi masalah petani di Desa Dawuhan. Selain itu, irigasi menggunakan pompa berbahan bakar fosil sangat boros terutama bagi petani\u201D",
    image: profileSukirno,
  },
  {
    name: "Muchtarom",
    role: "Ketua Harja Tani, KedungBenda",
    quote: "\u201CSetiap musim kemarau, persediaan air pasti habis. Sebagai petani kita harus bisa irigasi dengan jumlah air yang sedikit\u201D",
    image: profileMuctharom,
  },
  {
    name: "Suyitno",
    role: "Pengelola Kawista Emji Mernek, Cilacap",
    quote: "\u201CBeberapa hari sekali, petani harus menyiram pupuk ke lahan. Aktivitas ini sangat memakan waktu dan tenaga. Kami harap ada solusi yang lebih efektif\u201D",
    image: profileSuyitno,
  },
];
---

<section
  id="insight"
  class="bg-white py-20 md:py-28 lg:py-36"
  aria-labelledby="insight-heading"
>
  <div class="container-wide mx-auto px-4 sm:px-8 lg:px-16">
    <div class="grid lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-start">

      <!-- Left column — heading + description -->
      <div class="lg:sticky lg:top-32">
        <h2
          id="insight-heading"
          class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-primary-600 leading-tight"
        >
          Berdasarkan Pengalaman Nyata di Lapangan
        </h2>
        <p class="mt-5 text-base sm:text-lg text-neutral-500 leading-relaxed">
          Memahami keluh kesah yang dialami petani dan pihak lainnya terkait pengelolaan lahan dengan kondisi cuaca yang tidak menentu dan menyulitkan petani.
        </p>
      </div>

      <!-- Right column — testimonial cards -->
      <div class="space-y-10 md:space-y-12">
        {testimonials.map((t) => (
          <div class="group flex gap-5">
            <!-- Vertical accent bar (gray by default, green on hover) -->
            <div
              class="w-1 shrink-0 rounded-full bg-[#535353] transition-colors duration-300 group-hover:bg-[#58B00F]"
              aria-hidden="true"
            ></div>

            <!-- Content -->
            <div class="flex flex-col sm:flex-row gap-5 items-start">
              <!-- Profile image (already circular in the PNG) -->
              <Image
                src={t.image}
                alt={`Foto ${t.name}`}
                width={100}
                height={100}
                quality={90}
                class="w-[80px] h-[80px] sm:w-[100px] sm:h-[100px] shrink-0 object-contain"
                loading="lazy"
              />

              <!-- Text -->
              <div>
                <h3 class="text-xl sm:text-2xl font-bold text-neutral-900">
                  {t.name}
                </h3>
                <p class="text-sm sm:text-base text-neutral-400 mt-0.5">
                  {t.role}
                </p>
                <p class="mt-3 text-sm sm:text-base text-neutral-600 leading-relaxed">
                  {t.quote}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
