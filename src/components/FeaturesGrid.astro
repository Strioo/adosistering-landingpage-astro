---
/**
 * FeaturesGrid.astro — "Fitur" section
 * Design: Alternating layout (image ↔ text) for 4 features,
 * each with 2 sub-feature mini-cards with icons.
 * Matches the wooden-sign title style of other sections.
 */
import { Image } from "astro:assets";
import featureImg1 from "@/assets/images/feature-image-1.png";
import featureImg2 from "@/assets/images/feature-image-2.png";
import featureImg3 from "@/assets/images/feature-image-3.png";
import featureImg4 from "@/assets/images/feature-image-4.png";
import featureTitle from "@/assets/images/feature-title.png";

const features = [
  {
    title: "Energi Terbarukan Berbasis Panel Surya",
    description:
      "ADOSISTERING memanfaatkan panel surya sebagai sumber energi utama untuk mendukung operasional sistem irigasi. Dengan pendekatan ini, sistem dapat berjalan secara mandiri, efisien, dan ramah lingkungan, khususnya pada wilayah lahan yang terbatas akses listrik.",
    image: featureImg1,
    alt: "Panel surya sebagai sumber energi sistem irigasi pintar ADOSISTERING",
    subs: [
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
        title: "Panel Surya",
        description:
          "Sumber daya listrik dihasilkan melalui energi matahari untuk mendukung operasional sistem.",
      },
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
        title: "Efisiensi Biaya Operasional",
        description:
          "Mengurangi ketergantungan pada listrik konvensional sehingga biaya operasional jangka panjang menjadi lebih hemat.",
      },
    ],
  },
  {
    title: "Kontrol Irigasi",
    description:
      "pengelolaan sistem irigasi secara real-time melalui integrasi sensor dan kontrol pompa berbasis IoT.",
    image: featureImg2,
    alt: "Dashboard kontrol irigasi ADOSISTERING untuk mengatur pompa air secara remote",
    subs: [
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
        title: "Data Realtime",
        description:
          "Menampilkan kondisi lahan secara langsung untuk mendukung keputusan irigasi.",
      },
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>`,
        title: "Data cloud",
        description:
          "Seluruh data tersimpan dan dapat diakses melalui dashboard monitoring.",
      },
    ],
  },
  {
    title: "Sensor Kelembaban Tanah",
    description:
      "Sistem membaca tingkat kelembaban tanah secara berkala untuk menentukan kebutuhan irigasi yang optimal. Data ini menjadi dasar dalam mengatur ambang batas penyiraman agar penggunaan air lebih efisien.",
    image: featureImg3,
    alt: "Tampilan data sensor kelembaban tanah pada dashboard ADOSISTERING",
    subs: [
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
        title: "Database",
        description:
          "Data kelembaban tersimpan secara sistematis untuk analisis historis dan evaluasi kondisi lahan.",
      },
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
        title: "Pembantu Keputusan",
        description:
          "Sistem membantu menentukan waktu penyiraman yang tepat agar penggunaan air lebih efisien.",
      },
    ],
  },
  {
    title: "Riwayat Irigasi",
    description:
      "ADOSISTERING menyediakan rekam jejak aktivitas irigasi yang mencakup kelembaban tanah, debit aliran, volume air, serta status penyiraman untuk setiap blok lahan.",
    image: featureImg4,
    alt: "Tabel riwayat irigasi pada platform ADOSISTERING",
    subs: [
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
        title: "Catat Otomatis",
        description:
          "Seluruh aktivitas irigasi tercatat secara otomatis untuk memastikan transparansi dan akurasi data.",
      },
      {
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`,
        title: "Filter Riwayat",
        description:
          "Pengguna dapat menyaring data berdasarkan waktu atau blok lahan untuk menganalisis efektivitas sistem irigasi.",
      },
    ],
  },
];
---

<section
  id="fitur"
  class="bg-white py-16 md:py-24 lg:py-32"
  aria-labelledby="fitur-heading"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16">

    <!-- Title image — centered -->
    <div class="flex justify-center mb-16 md:mb-20">
      <Image
        src={featureTitle}
        alt="Fitur"
        width={480}
        quality={90}
        class="h-auto w-auto max-w-[240px] sm:max-w-[340px] md:max-w-[420px] lg:max-w-[480px]"
        loading="lazy"
      />
    </div>

    <!-- Features list — alternating layout -->
    <div class="space-y-20 md:space-y-28 lg:space-y-36">
      {features.map((feature, index) => {
        const imageFirst = index % 2 === 0;
        return (
          <div
            class:list={[
              "grid md:grid-cols-[5fr_6fr] gap-10 md:gap-14 lg:gap-20 items-start",
              !imageFirst && "md:grid-cols-[6fr_5fr]",
            ]}
          >
            {/* ── Image side ── */}
            <div
              class:list={[
                "rounded-2xl overflow-hidden shadow-lg",
                !imageFirst && "md:order-2",
              ]}
            >
              <Image
                src={feature.image}
                alt={feature.alt}
                width={700}
                quality={85}
                sizes="(max-width: 768px) 95vw, (max-width: 1280px) 50vw, 700px"
                class="w-full h-auto"
                loading="lazy"
              />
            </div>

            {/* ── Text side ── */}
            <div
              class:list={[
                "flex flex-col justify-center",
                !imageFirst && "md:order-1",
              ]}
            >
              <h3 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-primary-600 leading-tight mb-6">
                {feature.title}
              </h3>
              <p class="text-base sm:text-lg text-neutral-500 leading-relaxed mb-10">
                {feature.description}
              </p>

              {/* Sub-feature mini-cards */}
              <div class="grid grid-cols-2 gap-6 sm:gap-8">
                {feature.subs.map((sub) => (
                  <div>
                    {/* Icon */}
                    <div class="w-12 h-12 rounded-xl bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
                      <span set:html={sub.icon} />
                    </div>
                    <h4 class="text-base sm:text-lg font-bold text-neutral-900 mb-2">
                      {sub.title}
                    </h4>
                    <p class="text-sm sm:text-base text-neutral-500 leading-relaxed">
                      {sub.description}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
