---
import { Image } from "astro:assets";
import problemTitle from "@/assets/images/problem-title.png";
import problemImg1 from "@/assets/images/problem-feature-1.png";
import problemImg2 from "@/assets/images/problem-feature-2.png";
import problemImg3 from "@/assets/images/problem-feature-3.png";
import problemImg4 from "@/assets/images/problem-feature-4.png";

const problems = [
  {
    id: 1,
    title: "Penyiraman Dilakukan Hanya Berdasarkan Perkiraan",
    description: "Padahal, setiap tanaman membutuhkan jumlah air yang dan frekuensi irigasi yang berbeda.",
    image: problemImg1,
    alt: "Petani menyiram tanaman berdasarkan perkiraan",
  },
  {
    id: 2,
    title: "Penggunaan Air Tidak Efisien",
    description: "Irigasi yang dilakukan hanya berdasarkan perkiraan, mengakibatkan penggunaan air yang tidak efisien.",
    image: problemImg2,
    alt: "Sistem irigasi konvensional berbasis jadwal tetap",
  },
  {
    id: 3,
    title: "Sulitnya Memantau Kondisi Lahan",
    description: "Belum ada parameter yang dapat mengukur kondisi lahan supaya irigasi dapat lebih optimal.",
    image: problemImg3,
    alt: "Kesulitan memantau kondisi lahan pertanian",
  },
  {
    id: 4,
    title: "Risiko Tanaman Mengalami Kekurangan atau Kelebihan Air",
    description: "Tanaman yang mengalami kekurangan atau kelebihan air, tentunya akan berdampak pada hasil panen.",
    image: problemImg4,
    alt: "Penyiraman manual yang tidak efisien",
  },
];
---

<section
  id="masalah"
  class="bg-white py-16 md:py-24 lg:py-32"
  aria-labelledby="masalah-heading"
>
  <div class="container-wide mx-auto px-4 sm:px-8 lg:px-16">

    <!-- Title image — centered -->
    <div class="flex justify-center mb-20 md:mb-28">
      <Image
        src={problemTitle}
        alt="Masalah Umum Irigasi"
        width={560}
        height={160}
        quality={75}
        class="h-auto w-auto max-w-[280px] sm:max-w-[380px] md:max-w-[480px] lg:max-w-[560px]"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Problems list — alternating layout, full-width images -->
    <div class="space-y-20 md:space-y-28 lg:space-y-36">
      {problems.map((problem, index) => (
        <div
          class:list={[
            "grid md:grid-cols-[5fr_6fr] gap-10 md:gap-16 lg:gap-20 items-center",
            index % 2 !== 0 ? "md:[&>*:first-child]:order-2 md:[&>*:last-child]:order-1 md:grid-cols-[6fr_5fr]" : "",
          ]}
        >
          <!-- Text side -->
          <div class="space-y-4">
            <h3 class="text-3xl sm:text-4xl lg:text-[2.6rem] font-extrabold text-primary-600 leading-tight">
              {problem.title}
            </h3>
            <p class="text-base sm:text-lg text-neutral-500 leading-relaxed">
              {problem.description}
            </p>
          </div>

          <!-- Image — already contains browser chrome, display as-is -->
          <div>
            <Image
              src={problem.image}
              alt={problem.alt}
              width={700}
              height={520}
              quality={75}
              sizes="(max-width: 768px) 95vw, (max-width: 1280px) 50vw, 700px"
              class="w-full h-auto"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
