---
import { Image } from "astro:assets";

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  priority?: boolean;
  class?: string;
  quality?: number;
}

const {
  src,
  alt,
  width = 800,
  height,
  sizes = "(max-width: 640px) 100vw, (max-width: 1024px) 80vw, 60vw",
  priority = false,
  class: className = "",
  quality = 80,
} = Astro.props;

const isStringPath = typeof src === "string";
---

{isStringPath ? (
  <img
    src={src as string}
    alt={alt}
    width={width}
    height={height}
    loading={priority ? "eager" : "lazy"}
    decoding={priority ? "sync" : "async"}
    class={className}
  />
) : (
  <Image
    src={src as ImageMetadata}
    alt={alt}
    width={width}
    height={height ?? undefined}
    sizes={sizes}
    loading={priority ? "eager" : "lazy"}
    decoding={priority ? "sync" : "async"}
    fetchpriority={priority ? "high" : "auto"}
    quality={quality}
    class={className}
  />
)}
