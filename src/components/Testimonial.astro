---
/**
 * Testimonial.astro — "Pandangan Direktur" section
 * Design: Quote from Suharto, S.Pd., M.Kom with photo
 */
import ImageOptim from "./ImageOptim.astro";
---

<section
  class="section-padding bg-gradient-to-b from-neutral-50 to-white"
  aria-labelledby="testimonial-heading"
>
  <div class="container-narrow mx-auto">
    <div class="text-center mb-10">
      <h2 id="testimonial-heading" class="section-title">
        Pandangan <span class="gradient-text">Direktur</span>
      </h2>
    </div>

    <div class="card p-8 md:p-12 text-center max-w-3xl mx-auto">
      <!-- Quote icon -->
      <div class="mb-6" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto text-primary-200" viewBox="0 0 24 24" fill="currentColor">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
        </svg>
      </div>

      <!-- Quote text -->
      <blockquote>
        <p class="text-body-lg md:text-xl text-neutral-700 leading-relaxed italic mb-8">
          "Kami percaya bahwa teknologi IoT dapat menjadi solusi nyata bagi tantangan irigasi pertanian di Indonesia.
          Melalui ADOSISTERING, kami berkomitmen untuk mewujudkan pertanian yang lebih efisien, hemat air,
          dan berkelanjutan demi kesejahteraan petani Indonesia."
        </p>
      </blockquote>

      <!-- Author -->
      <div class="flex items-center justify-center gap-4">
        <!-- TODO: replace with actual director photo -->
        <ImageOptim
          src="/images/placeholder-director.svg"
          alt="Foto Suharto, S.Pd., M.Kom — Direktur ADOSISTERING"
          width={64}
          height={64}
          class="w-16 h-16 rounded-full object-cover ring-4 ring-primary-100"
        />
        <div class="text-left">
          <cite class="not-italic font-bold text-neutral-900">Suharto, S.Pd., M.Kom</cite>
          <p class="text-sm text-neutral-500">Direktur ADOSISTERING</p>
        </div>
      </div>
    </div>
  </div>
</section>
