---
/**
 * Footer.astro — "Mari Terhubung & Berkolaborasi" footer section
 * Design: Dark footer with logo, social links, navigation, and copyright
 */
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    label: "Instagram",
    href: "https://instagram.com/adosistering",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/company/adosistering",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: "YouTube",
    href: "https://youtube.com/@adosistering",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>`,
  },
];

const footerLinks = [
  { label: "Beranda", href: "#beranda" },
  { label: "Masalah", href: "#masalah" },
  { label: "Solusi", href: "#solusi" },
  { label: "Fitur", href: "#fitur" },
  { label: "Lokasi", href: "#lokasi" },
  { label: "Hubungi Kami", href: "#hubungi-kami" },
];
---

<footer
  class="bg-primary-900 text-white"
  role="contentinfo"
>
  <!-- Top section: CTA banner -->
  <div class="bg-primary-800 border-b border-primary-700/50">
    <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
        Mari Terhubung & Berkolaborasi
      </h2>
      <p class="text-white/70 max-w-xl mx-auto mb-6 text-sm md:text-base">
        Ikuti perkembangan terbaru teknologi irigasi pintar dan dapatkan informasi eksklusif dari kami.
      </p>
      <div class="flex justify-center gap-3">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-11 h-11 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-full transition-colors duration-200"
              aria-label={`Ikuti kami di ${social.label}`}
            >
              <span set:html={social.icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Bottom section: nav + copyright -->
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2" aria-label="ADOSISTERING — Kembali ke beranda">
        <!-- TODO: replace with actual white logo -->
        <img
          src="/logos/logo-white.svg"
          alt="Logo ADOSISTERING"
          width="140"
          height="32"
          class="h-7 w-auto"
          loading="lazy"
        />
      </a>

      <!-- Footer nav -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <!-- Divider -->
    <div class="border-t border-primary-800 mt-6 pt-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/50">
        <p>&copy; {currentYear} ADOSISTERING. Seluruh hak cipta dilindungi undang-undang.</p>
        <p>
          Dibuat dengan
          <span aria-label="cinta" class="text-red-400">♥</span>
          untuk pertanian Indonesia
        </p>
      </div>
    </div>
  </div>
</footer>
