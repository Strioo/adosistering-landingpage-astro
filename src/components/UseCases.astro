---
/**
 * UseCases.astro — "Lokasi Implementasi & Uji Lapangan"
 * Design: Shows implementation locations with images/map
 */
import ImageOptim from "./ImageOptim.astro";
---

<section
  id="lokasi"
  class="section-padding bg-neutral-50"
  aria-labelledby="lokasi-heading"
>
  <div class="container-wide mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        Lokasi
      </div>
      <h2 id="lokasi-heading" class="section-title">
        Lokasi Implementasi & <span class="gradient-text">Uji Lapangan</span>
      </h2>
      <p class="section-subtitle">
        Sistem ADOSISTERING telah diuji coba dan diimplementasikan di beberapa lokasi pertanian di Indonesia.
      </p>
    </div>

    <!-- Locations Grid -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      <!-- Location Card 1 -->
      <div class="card overflow-hidden group">
        <div class="aspect-video overflow-hidden rounded-xl mb-4">
          <!-- TODO: replace with actual location photo -->
          <ImageOptim
            src="/images/placeholder-locations.svg"
            alt="Lokasi uji coba sistem irigasi pintar ADOSISTERING di lahan pertanian"
            width={600}
            height={400}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <h3 class="text-heading-sm text-neutral-900 mb-2">Lokasi Uji Coba 1</h3>
        <p class="text-body-sm text-neutral-600">
          Implementasi sistem irigasi otomatis pada lahan padi seluas 20+ hektar dengan sensor kelembaban dan kontrol pompa jarak jauh.
        </p>
        <div class="mt-3 flex items-center gap-2 text-sm text-primary-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <!-- TODO: Replace with actual location -->
          <span>Indonesia</span>
        </div>
      </div>

      <!-- Location Card 2 -->
      <div class="card overflow-hidden group">
        <div class="aspect-video overflow-hidden rounded-xl mb-4">
          <ImageOptim
            src="/images/placeholder-locations.svg"
            alt="Lokasi implementasi irigasi cerdas ADOSISTERING di perkebunan"
            width={600}
            height={400}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <h3 class="text-heading-sm text-neutral-900 mb-2">Lokasi Uji Coba 2</h3>
        <p class="text-body-sm text-neutral-600">
          Pilot project sistem irigasi berbasis energi surya dengan monitoring suhu dan kelembaban real-time.
        </p>
        <div class="mt-3 flex items-center gap-2 text-sm text-primary-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>Indonesia</span>
        </div>
      </div>

      <!-- Location Card 3 -->
      <div class="card overflow-hidden group">
        <div class="aspect-video overflow-hidden rounded-xl mb-4">
          <ImageOptim
            src="/images/placeholder-locations.svg"
            alt="Lokasi demonstrasi teknologi irigasi IoT ADOSISTERING"
            width={600}
            height={400}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <h3 class="text-heading-sm text-neutral-900 mb-2">Lokasi Uji Coba 3</h3>
        <p class="text-body-sm text-neutral-600">
          Demonstrasi dan pelatihan penggunaan teknologi IoT untuk pertanian modern kepada kelompok tani lokal.
        </p>
        <div class="mt-3 flex items-center gap-2 text-sm text-primary-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>Indonesia</span>
        </div>
      </div>
    </div>
  </div>
</section>
