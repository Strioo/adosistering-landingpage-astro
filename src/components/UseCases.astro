---
/**
 * UseCases.astro — "Lokasi Implementasi & Uji Lapangan"
 * Design: Large green title, 3 location cards over a map background
 * with decorative green dot-grid patterns on left & right sides.
 */
import { Image } from "astro:assets";
import mapBg from "@/assets/images/map-background.png";
import imgKedungbenda from "@/assets/images/implement-kedungbenda.png";
import imgMernekJenek from "@/assets/images/implement-mernek_jenek.png";
import imgDawuhan from "@/assets/images/implement-dawuhan.png";

const locations = [
  {
    name: "Desa KedungBenda, Purbalingga",
    image: imgKedungbenda,
    description:
      "ADOSISTERING mengintegrasikan sensor, kontrol pompa, dan dashboard monitoring untuk membantu petani mengambil keputusan irigasi yang tepat.",
  },
  {
    name: "Kawista Emji Mernek Jenek, Cilacap",
    image: imgMernekJenek,
    description:
      "ADOSISTERING mengintegrasikan sensor, kontrol pompa, dan dashboard monitoring untuk membantu petani mengambil keputusan irigasi yang tepat.",
  },
  {
    name: "Desa Dawuhan, Banyumas",
    image: imgDawuhan,
    description:
      "ADOSISTERING mengintegrasikan sensor, kontrol pompa, dan dashboard monitoring untuk membantu petani mengambil keputusan irigasi yang tepat.",
  },
];
---

<section
  id="implementasi"
  class="bg-white py-16 md:py-24 lg:py-32 overflow-hidden"
  aria-labelledby="lokasi-heading"
>
  <div class="container-full px-4 sm:px-6 lg:px-12 xl:px-16">

    <!-- Section title — large green bold text, centered -->
    <h2
      id="lokasi-heading"
      class="text-center text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold text-primary-500 leading-tight mb-14 md:mb-20"
    >
      Lokasi Implementasi<br />& Uji Lapangan
    </h2>

    <!-- Cards area with map background + dot decorations -->
    <div class="relative pt-4 pb-20 md:pb-28 lg:pb-36 min-h-[600px] md:min-h-[700px] lg:min-h-[800px] flex items-center">

      <!-- Map background image — sits behind the cards -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none" aria-hidden="true">
        <Image
          src={mapBg}
          alt=""
          width={1344}
          quality={80}
          class=" object-cover"
          loading="lazy"
        />
      </div>

      <!-- 3 Location cards -->
      <div class="relative z-10 grid md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto w-full">
        {locations.map((loc) => (
          <div class="bg-white rounded-2xl shadow-lg border border-neutral-100 p-4 sm:p-5">
            <!-- Image with green border/frame -->
            <div class="rounded-xl overflow-hidden mb-5">
              <Image
                src={loc.image}
                alt={`Lokasi implementasi ADOSISTERING di ${loc.name}`}
                width={500}
                quality={85}
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
            <!-- Location name -->
            <h3 class="text-lg sm:text-xl font-bold text-neutral-900 mb-2 leading-snug">
              {loc.name}
            </h3>
            <!-- Description -->
            <p class="text-sm sm:text-base text-neutral-500 leading-relaxed">
              {loc.description}
            </p>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
